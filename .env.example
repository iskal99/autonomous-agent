# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_REPOSITORY=iskal99/autonomous-agent
GITHUB_OWNER=iskal99

# Anthropic API (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Agent Configuration
AGENT_MODE=autonomous
AGENT_DEBUG=false
AGENT_VERBOSE=true

# Git Configuration
GIT_USER_NAME=AutonomousAgent
GIT_USER_EMAIL=agent@autonomous.dev

# Logging
LOG_LEVEL=INFO
LOG_FILE=agent.log

# Optional: Slack/Discord notifications
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
