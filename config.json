{\n  "agent": {\n    "name": "AutonomousDevAgent",\n    "version": "1.0.0",\n    "description": "Agent IA autonome pour développement et automatisation",\n    "autonomy_level": "advanced",\n    "model": "claude-3"\n  },\n  "execution": {\n    "auto_create_branches": true,\n    "auto_commit": true,\n    "auto_create_pr": true,\n    "require_tests": true,\n    "require_documentation": true,\n    "max_retries": 3,\n    "timeout_seconds": 3600\n  },\n  "tasks": {\n    "feature_development": true,\n    "bug_fixing": true,\n    "test_generation": true,\n    "documentation": true,\n    "code_refactoring": true,\n    "performance_optimization": true\n  },\n  "rules": {\n    "never_delete_without_backup": true,\n    "always_test_before_commit": true,\n    "require_pr_review": false,\n    "auto_merge_if_green": false,\n    "code_coverage_minimum": 80\n  },\n  "tools": {\n    "git": {\n      "enabled": true,\n      "auto_stash": true\n    },\n    "github": {\n      "enabled": true,\n      "create_issues": true,\n      "create_pr": true\n    },\n    "python": {\n      "enabled": true,\n      "version": "3.11+"\n    },\n    "nodejs": {\n      "enabled": true,\n      "version": "18+"\n    },\n    "docker": {\n      "enabled": false\n    }\n  },\n  "logging": {\n    "level": "INFO",\n    "file": "agent.log",\n    "max_size_mb": 100,\n    "backup_count": 5\n  },\n  "notifications": {\n    "slack": false,\n    "email": false,\n    "github_comments": true\n  }\n}\n